# SanJuan AI KI backend/runtime environment
SANJUAN_ENV=development
SANJUAN_RETRIEVAL_MODE=hybrid
SANJUAN_API_VERSION=0.6.0

# Comma-separated web origins allowed to call the API.
# Local development defaults to http://localhost:3000 and http://127.0.0.1:3000 if unset.
# Production should set this explicitly to the deployed web origin.
SANJUAN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Keep false unless the frontend needs cookies or authenticated browser credentials.
SANJUAN_CORS_ALLOW_CREDENTIALS=false

# MVP in-memory abuse protection for /ask.
# This is useful for demos and single-process deployments, but production should also use edge/API-gateway protection.
SANJUAN_RATE_LIMIT_ENABLED=true
SANJUAN_ASK_RATE_LIMIT_PER_MINUTE=30
